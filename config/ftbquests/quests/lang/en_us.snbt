	quest.58A05E9960629A37.quest_desc: ["The Dragon Master of the Indigo Plateau, Lance flies across regions to protect Pokémon. His iconic red cape is as legendary as his Dragonite."]
	quest.58A05E9960629A37.quest_subtitle: "&bRecommended: ~Lv 85"
	quest.58A05E9960629A37.title: "Lance"
	quest.58FF2A849EA93A2B.quest_desc: ["The Mechanical Press is a mechanical component that applies Pressing, Packing, and Compacting recipes to items below it"]
	quest.58FF2A849EA93A2B.title: "Mechanical Press"
	quest.591316BFBA990E50.title: "&fA Wild &eReshiram &fAppeared!"
	quest.5923FFED41A88020.quest_desc: ["&fKaty, the Bug-type Gym Leader of Cortondo, is one of the official Paldea Gym World Tour battles. Defeat this leader, claim the matching badge, and continue your regional progression."]
	quest.5923FFED41A88020.quest_subtitle: "&bUnlocked Level Cap: Lv 100"
	quest.5923FFED41A88020.title: "Katy"
	quest.595674619F5B5499.quest_desc: ["These Pokémon come from a region with a rich industrial history, but here they’ve adapted to their new environment. Begin your study with 25 of them and observe how, even in this transformed world, their presence remains intact."]
	quest.595674619F5B5499.title: "Obtain 25 different Pokémon from Generation 8's Pokédex"
	quest.59715C99CC58A407.quest_desc: [
		"The Fluid Tank is a fluid storage that can store up to 8 buckets of fluid per block."
		"Fluid tanks will also merge with adjacent tanks up to 3x32x3, allowing to store up 2,304 buckets of any fluid."
	]
	quest.5971EEEDACF7F8F6.quest_desc: [""]
	quest.5971EEEDACF7F8F6.quest_subtitle: "&aRotating spinny wheels of death. Items go in, and are crushed into their smaller bits. Also used as part of ore processing to triple your yield.&r"
	quest.5971EEEDACF7F8F6.title: "Craft Crushing Wheel"
	quest.599BA61151622261.quest_desc: ["Here, Pokémon from Paldea interact with their environment in unique ways. Even outside their native region, they retain unique behaviors. You are venturing into a very modern field of study."]
	quest.599BA61151622261.title: "Obtain 80 different Pokémon from Generation 9's Pokédex"
	quest.5A0187C7D97C2BCE.quest_subtitle: "&bMountain"
	quest.5A22B4FE2588B4F5.quest_subtitle: "Great for moving items from one spot to another within reach without the need for &dfiddly belt setups&r."
	quest.5A22B4FE2588B4F5.title: "Craft &6Mechanical Arm"
	quest.5A24F6E8B7ADCB84.quest_desc: ["You’ve reached the pinnacle of this study. The 100 Pokémon from Johto are now documented, understood, and respected. You’ve captured the depth of this region through their essence. Even in this reimagined world, their memory lives through you. Continue to pass on this legacy."]
	quest.5A24F6E8B7ADCB84.title: "Obtain 100 different Pokémon from Generation 2's Pokédex"
	quest.5A983410CE314652.quest_subtitle: "Are You Ready? You Only Get 1 Shot."
	quest.5A983410CE314652.title: "Catch the whole trio of legendary felines"
	quest.5ADB6B70E40F1994.title: "Heal Ball 2013 9"
	quest.5AF9A466501FF923.quest_subtitle: "&bRecommended: ~Lv 66"
	quest.5AF9A466501FF923.title: "Cheren"
	quest.5B1E1D0A9429482A.title: "&fA Wild &dCresselia &fAppeared!"
	quest.5B4135D9ECC778AA.quest_desc: [
		"The &eInventory Connector&r links your different storages together."
		""
		"Connected inventories can then be accessed through the &eStorage Terminal&r."
	]
	quest.5B6A510004D90693.quest_desc: ["&fNorman, the Normal-type Gym Leader of Petalburg City, is one of the official Hoenn Gym World Tour battles. Defeat this leader, claim the matching badge, and continue your regional progression."]
