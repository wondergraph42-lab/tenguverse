	quest.7DFE370FAD123FF1.quest_desc: [
		"&6&l🏆 Alola Trainer Progression"
		""
		"&fAlola’s battle path is not yet available in Cobblemon Realms, but it will come in a future update!"
		""
		"&c⚠ No Trainer Series Available Yet:&r  "
		"&7Currently, no Gym Leaders or Trainer series have been implemented for Alola. Stay tuned for future updates as we expand the adventure!"
		""
		"&9🎯 In the meantime:&r  "
		"&rWe recommend selecting a Trainer path from another region or generation. You can switch at any time by exchanging a &6Relic Coin&r."
		""
		"&6Thank you for your patience, Trainer. Great things await in Alola!"
	]
	quest.7DFE370FAD123FF1.title: "&6Alola Trainer Progression"
	quest.7E534F446000B120.title: "&fA Wild &dRayquaza &fAppeared!"
	quest.7E5C72750017BBA4.quest_desc: ["The shaft is a basic mechanical component in Create. A shaft can be used to connect two mechanical components such that the rotation of one rotates the other, and shafts serve as the only blocks upon which Mechanical Belts can be placed. "]
	quest.7E5C72750017BBA4.title: "Shaft"
