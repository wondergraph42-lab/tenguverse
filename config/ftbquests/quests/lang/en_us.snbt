	quest.322DD3E3032D83FA.title: "&6Kalos Trainer Progression"
	quest.3232BA2D5E7F23C0.quest_subtitle: "&bGrassland, Hills, Lush"
	quest.3269DBDB2904B394.quest_desc: [
		"Using the quest book is quite simple. The Left side of the screen is known as tabs. Each tab has quest trees which you can see in each tab. "
		"Clicking and dragging outside of a quest will move the page around. Clicking on a quest will open it. The quest tasks are on the left side and are automatically detected from your inventry or your interactions with the world. "
		"The rewards for completing quests are on the right and will unlock once all tasks of the quest are completed. "
		"The left arrow at the top of a quest will tell you what quests are required for the quest to unlock. The right arrow will tell you what completing that quest will unlock. "
		"You can scroll in or out on the interface using the scroll wheel. "
		"Finally the quests lines and individual quests are hidden until you have unlocked the quest before it. They will unlock and open up as you progress through the pack. "
	]
	quest.32703CF33AD93C2F.quest_desc: ["&fIono, the Electric-type Gym Leader of Levincia, is one of the official Paldea Gym World Tour battles. Defeat this leader, claim the matching badge, and continue your regional progression."]
	quest.32703CF33AD93C2F.quest_subtitle: "&bUnlocked Level Cap: Lv 100"
	quest.32703CF33AD93C2F.title: "Iono"
	quest.32B00B671E8CFC02.quest_subtitle: "&bRecommended: ~Lv 73"
	quest.32B9EAE28E1C5D7A.quest_desc: [""]
	quest.32B9EAE28E1C5D7A.quest_subtitle: "&cThe Electron Tube is an item that is only used in crafting recipes.&r"
	quest.32EADB907CE20E2B.quest_subtitle: "&bBadlands, Spooky, Taiga"
	quest.33187D40C49EF688.quest_desc: ["The Speedometer measures the speed of Rotational Force"]
	quest.338E3B8AA2896C32.quest_desc: [
		"&dFTBChunks &rlets you claim chunks to secure your builds and valuables. Once claimed, these chunks will be protected from damage by other players and mobs."
		""
		"&e&lHow to Claim Chunks:&r&r\\n1. Open your map (default: &6J&r).\\n2. Ensure the FTBChunks overlay button on the left is enabled.\\n3. Left-click on a chunk to claim it.\\n4. Shift-Left-click to load and keep it active.\\n5. Right-click to unclaim the chunk."
	]
	quest.338E3B8AA2896C32.quest_subtitle: "Protect your base with FTBChunks"
	quest.338E3B8AA2896C32.title: "&l&5FTB Chunks"
	quest.33E3942F8D058647.title: "Kalos Master"
	quest.34346949C3804907.quest_desc: ["As always, it's best to press and hold &b'Ponder'&r to see it in action."]
	quest.34346949C3804907.quest_subtitle: "&ePloughs&r can clear non-collision blocks (think torches etc) and create farmland from dirt, but their best use is for &cyeeting entities&r."
