	quest.0000000000000742.quest_desc: ["The Arc Furnace is a 5×5×5 multiblock used for smelting ores and dust into ingots and creating alloys."]
	quest.0000000000000742.title: "Arc Furnace"
	quest.000000000000074C.quest_desc: ["The Excavator is a 8×3×7 multiblock that mines into Mineral Deposits below bedrock."]
