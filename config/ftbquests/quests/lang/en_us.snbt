	quest.24620A08F6590AAA.quest_desc: ["Your pokemon may need to heal. If you wait, they will automatically revive but this could take a while, so you will want one of these machines so you can heal them right away and get back into the fight"]
	quest.249EA3CDB4AD7243.quest_subtitle: "Are You Ready? You Only Get 1 Shot."
	quest.249EA3CDB4AD7243.title: "Catch the legendary trio of birds"
	quest.24F71DDFE01F3D0F.quest_subtitle: "Praise be to the Helix!"
	quest.24F71DDFE01F3D0F.title: "The Spiral’s Secret"
	quest.251F8B7F42827A2D.title: "Capture the legendary &bFini"
	quest.2541EB890D364B99.quest_subtitle: "&bRecommended: ~Lv 29"
	quest.25624D61C006C098.quest_desc: ["You’ve accomplished what few have before you. The 151 Pokémon from Kanto... documented, captured, studied. Even in a modified world, their essence endures. Congratulations. You are now part of the living memory of this region."]
	quest.25624D61C006C098.title: "Obtain 151 different Pokémon from Generation 1's Pokédex"
	quest.2573B61CDE9D1479.title: "Johto Master"
	quest.2595CD4D52049FED.title: "Eevee"
	quest.25B25D7A328B248D.quest_desc: [
		"The Linear Chassis is one method of connecting up Contraptions. "
		"Linear Chassis will automatically connect to adjacent and equally aligned chassis"
	]
	quest.25B25D7A328B248D.title: "Linear Chassis"
	quest.25F1493EA6A7375A.quest_desc: ["They say finding this place is even rarer than finding a shiny pokemon"]
	quest.25F1493EA6A7375A.title: "Mirage island"
	quest.262BCEE90F609351.title: "Level Emitter"
	quest.263C0F225E13717A.quest_desc: ["Johto is home to Pokémon with a mystical essence. Some only reveal themselves to those with a pure heart. Among the 90 you’re about to encounter, you may feel a deep connection between humans, Pokémon… and the sacred. Be respectful on your journey."]
	quest.263C0F225E13717A.title: "Obtain 90 different Pokémon from Generation 2's Pokédex"
