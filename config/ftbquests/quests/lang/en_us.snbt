	quest.49D23A0468112B2D.quest_desc: [
		"&e&lYour First Gym Challenge:&r"
		""
		"* Brock is the very first Gym Leader of the &6Cobblemon Realms World Tour&r."
		"* He specializes in &fRock-type Pokémon&r and is designed to introduce players to the Gym progression system."
		"* Before challenging him, make sure your team is properly prepared and not above the current level cap."
		"{@pagebreak}"
		""
		"&e&lWhere to Find Brock:&r"
		""
		"* You can explore your world naturally to discover a &fGym Arena&r."
		"* If you do not want to search, you can also travel directly to the &fSpawn Island&r."
		"* Near the &fPokéCenter&r, you will find a large &6Arena Building&r containing the first Gym challenge."
		"* Enter the arena to begin your journey through the Cobblemon Realms Tour."
		"{@pagebreak}"
		""
		"&e&lTips Against Brock:&r"
		""
		"* Rock-type Pokémon are weak against &fWater&r, &fGrass&r, &fGround&r, &fSteel&r, and &fFighting&r attacks."
		"* Avoid relying only on Fire, Flying, or Normal-type Pokémon early on."
		"* Capturing a Water or Grass Pokémon before your first Gym battle is highly recommended."
	]
	quest.49D23A0468112B2D.quest_subtitle: "&bCobblemon Realms World Tour"
	quest.49D23A0468112B2D.title: "&bYour First Gym Challenge"
	quest.4A49AEFC31374580.quest_desc: [
		"The Accumulator is a multi-block structure, it can store large amount of RF."
		"{image:ftbquests:textures/quests/create_accumulator.png width:150 height:100 align:1}"
		"The maximum size is a 3x5x3 and can hold 188.8MRF"
	]
	quest.4A4E4AD82FF86BF5.quest_desc: ["With your fossil identified, it's time to take a closer look! The Fossil Analyzer will provide more details about its origins and potential restoration."]
	quest.4A4E4AD82FF86BF5.quest_subtitle: "A deeper look into ancient remains!"
	quest.4A5394CDF4920501.quest_desc: [
		""
		"This guide is here to introduce you to the fundamentals of our core mods and provide a few challenges for you to tackle."
		""
		"Click on the checkmarks to claim your rewards."
		""
		"Hover your mouse over the left side of the screen to access the menu items."
		""
		"[\"\",{\"text\":\"Click For Official Cobblemon Wiki\",\"color\":\"gold\",\"bold\":true,\"underlined\":false,\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://wiki.cobblemon.com\"}}]"
		""
		"&e&lTrainer Tips:&r&r\\n- Hit \"&eG&r\" to open your party summary and select a starter! \\n- Certain Pokémon appear only in specific biomes or during specific times.\\n- Utilize the new &cpokedex&r to discover more about Pokémon spawns.\\n- Explore additional Cobblemon quests across the chapters on the left!"
		"{@pagebreak}"
	]
	quest.4A5394CDF4920501.quest_subtitle: "Welcome To Cobblemon Realms"
	quest.4A67FCABB56FC720.quest_desc: ["Do you got too many enchantment books? The filing cabinent holds 1 type of item, but all of them. So you can fill it with enchantment books!"]
	quest.4A67FCABB56FC720.quest_subtitle: "Enchantment Storage"
	quest.4A964B78D5390B6A.quest_subtitle: "&eSpouts&r are used to fill &9liquid containers&r. &eSpouts&r themselves must have their liquid pumped into them as they cannot be manually accessed."
	quest.4A964B78D5390B6A.title: "Craft &6Spout"
	quest.4AF3238551E346E1.title: "Craft &cHand Crank"
	quest.4AFCFC5B50979259.quest_subtitle: "The &aPrecision Mechanism&r is one of many &9Crafting Components&r."
	quest.4AFCFC5B50979259.title: "Craft &ePrecision Mechanism"
