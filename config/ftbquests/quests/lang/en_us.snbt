	quest.08BE9FD500231291.quest_desc: ["Marshal, a master of Fighting-type Pokémon, is a dedicated martial artist and former student of Alder. His strength lies in discipline and physical prowess, believing that Pokémon battles mirror the spirit of training the body and mind."]
	quest.08BE9FD500231291.quest_subtitle: "&bRecommended: ~Lv 85"
	quest.08BE9FD500231291.title: "Marshal"
	quest.08C535D38E761D21.quest_desc: ["🌍 Wise and experienced, Bertha focuses on inner strength and patience — her Pokémon reflect the calm power of the earth."]
	quest.08C535D38E761D21.quest_subtitle: "&bRecommended: ~Lv 59"
	quest.090C801EEFF5807D.quest_desc: ["Alola revealed brand new evolutionary forms. Changes like the Alolan forms are a direct result of local conditions—a blend of ecosystems and cultures. By capturing 60 Pokémon, you'll witness this fascinating phenomenon and perhaps learn more about this region’s unique evolutionary process."]
	quest.090C801EEFF5807D.title: "Obtain 60 different Pokémon from Generation 7's Pokédex"
	quest.09207E07B62161E8.title: "Capture the legendary &eTerrakion"
	quest.0938789D3870FED2.quest_desc: ["Have you heard of Kyogre, Groudon, and Rayquaza? These beings embody the world’s fundamental forces: sea, land, and sky. Even if you don’t encounter them, many Pokémon from Hoenn still bear traces of their influence. Once you’ve captured 100 species, you’ll be close to the mythological core of this region."]
	quest.0938789D3870FED2.title: "Obtain 100 different Pokémon from Generation 3's Pokédex"
	quest.0939C255CD8D6F52.quest_desc: [
		"&fSpikemuth's Dark-type Gym Leader battles with grit and raw strategy."
		"&fDefeat Piers to claim the Dark Badge."
	]
	quest.0939C255CD8D6F52.quest_subtitle: "&bUnlocked Level Cap: Lv 100"
	quest.0939C255CD8D6F52.title: "Piers"
	quest.096707FE505F1ED5.title: "Galar Master"
	quest.0997C666FC84BF8A.quest_subtitle: "The &bStressometer&r is used to measure the amount of &cStress&r on a &aShaft&r. This stress is the load of the system."
	quest.0997C666FC84BF8A.title: "Craft a Stressometer"
	quest.09DD54EE83E83325.quest_desc: [
		"&fWant to become part of the world of &bCobblemon Realms&f?"
		"&fWith the &dStorykeeper&f Patreon tier, you can create your own &fcustom trainer, permanently added to the modpack."
		""
		"&fYour trainer will:"
		"&b• &fAppear in the world as a roaming challenger"
		"&b• &fHave a fully customized Pokémon team"
		"&b• &fFeature your own Minecraft skin"
		"&b• &fInclude a dedicated Quest Book page"
		"&b• &fOffer a unique reward when defeated"
		""
		"&fThis is not a cosmetic bonus."
		"&fYour trainer becomes a real part of the adventure."
		""
		"&e&lHow to unlock it"
		"&fSupport the project on Patreon and unlock the &dStorykeeper&f tier."
		""
		"&fOnce unlocked, you will be contacted to submit:"
		"&b• &fTrainer name"
		"&b• &fMinecraft skin"
		"&b• &fPokémon team"
		"&b• &fOptional RP description"
		"&b• &fBattle reward"
		""
		"&fMore info available bellow:"
		"{\"text\":\"Click Here\",\"italic\":true,\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.patreon.com/c/ourstorycollection/membership\"}}"
	]
	quest.09DD54EE83E83325.quest_subtitle: "&7Storykeeper Patreon Exclusive"
	quest.09DFEDF05A1F9109.quest_desc: ["A famous movie star and Kalos Champion, Diantha perfectly balances beauty and strength. Though admired on screen, her true fans know her passion lies in Pokémon battles — especially with her signature Gardevoir."]
	quest.09DFEDF05A1F9109.quest_subtitle: "&bRecommended: ~Lv 100"
	quest.09DFEDF05A1F9109.title: "Diantha"
	quest.0A1D152E33182545.quest_subtitle: "&bRecommended: ~Lv 93"
	quest.0A1D152E33182545.title: "Drake"
	quest.0A317CDB453CDC15.quest_desc: [
		"&fGoldenrod City's Normal-type Gym Leader hides brutal power behind a cheerful smile."
		"&fDefeat Whitney to claim the Plain Badge."
	]
	quest.0A317CDB453CDC15.quest_subtitle: "&bUnlocked Level Cap: Lv 35"
	quest.0A317CDB453CDC15.title: "Whitney"
	quest.0B08BFBBC2A427AB.quest_desc: ["The Train Observer is used to detect passing Trains."]
	quest.0B60DD31E8E2B6E7.title: "&fA Wild &bManaphy &fAppeared!"
	quest.0B8785A83BA2C3CF.title: "&fA Wild &aShaymin &fAppeared!"
	quest.0BB3409343A6D592.quest_desc: ["Caitlin, known for her immense psychic power, once appeared in the Battle Castle of Sinnoh. Now a composed and regal member of the Elite Four, her calm demeanor hides an overwhelming force of Psychic energy."]
	quest.0BB3409343A6D592.quest_subtitle: "&bRecommended: ~Lv 85"
	quest.0BB3409343A6D592.title: "Caitlin"
	quest.0BB92CBE08A783C6.quest_desc: ["&fA Humid Mulch makes the Berry Tree act like it's in a Jungle or Swamp biome for an infinite duration. "]
	quest.0BD6AEABA59BD4B7.quest_desc: ["Unova is a cosmopolitan region, home to Pokémon from many biomes and carrying diverse philosophies. Study this diversity and discover what true unity in difference means."]
	quest.0BD6AEABA59BD4B7.title: "Obtain 80 different Pokémon from Generation 5's Pokédex"
	quest.0BEDD61CABE9D486.title: "Capture the legendary &cEntei"
	quest.0BFAEEF599FEA7D7.quest_desc: [
