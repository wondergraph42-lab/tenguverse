	quest.0DEBC61F8E0B71C2.quest_desc: [
		"To share your quests with your friends, you need to create a team."
		""
		"To do this, type the command: \"/ftbteams party create\" or use the menu at top left."
		""
		"From here, you can click on Settings to configure your team (name, color, description, etc.)."
		""
		"Now you can add your friends from the same interface and start your shared adventure together."
	]
	quest.0DEBC61F8E0B71C2.quest_subtitle: "Read my description!"
	quest.0DEBC61F8E0B71C2.title: "&eFTB Teams"
	quest.0E24A6FDB7149DE6.quest_desc: ["The deployer will be useful for making assembly crafts."]
	quest.0E24A6FDB7149DE6.quest_subtitle: "autoclicker"
	quest.0E30AF17F98585EE.quest_desc: ["Clad in knightly armor, Wikstrom dreams of valor and nobility. A Steel-type expert, he brings honor to his battles and always encourages trainers to fight with dignity and respect."]
	quest.0E30AF17F98585EE.quest_subtitle: "&bRecommended: ~Lv 100"
	quest.0E30AF17F98585EE.title: "Wikstrom"
	quest.0E47DBC64E3305D3.title: "Capture the legendary &aCalyrex"
	quest.0E501338CD6306A1.quest_desc: ["&fSkyla, the Flying-type Gym Leader of Mistralton City, is one of the official Unova Gym World Tour battles. Defeat this leader, claim the matching badge, and continue your regional progression."]
	quest.0E501338CD6306A1.quest_subtitle: "&bUnlocked Level Cap: Lv 87"
	quest.0E501338CD6306A1.title: "Skyla"
