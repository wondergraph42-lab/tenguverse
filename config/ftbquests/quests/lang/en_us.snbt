	quest.353657F699F6DCE6.quest_desc: [
		"The Large Water Wheel is a bigger version of the Water Wheel."
		"Can generate more stress unit."
		""
		"You can also change her wood type by simply right-click a plank into it. (compatible with any planks, except Chipped)"
	]
