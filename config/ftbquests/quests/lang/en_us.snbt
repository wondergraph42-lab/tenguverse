	quest.4ED84FC47E4FEFFB.quest_subtitle: "&bMountain, Taiga"
	quest.4F33E4856D85753B.quest_desc: ["The &eCrafting Terminal&r works like the standard terminal but allows you to craft using items directly from your &bnetwork&r."]
	quest.4F4579030B990452.quest_desc: ["A passionate chef and Water-type specialist, Siebold views battling as an art form. To him, crafting a meal and constructing a team share the same elegance and precision."]
