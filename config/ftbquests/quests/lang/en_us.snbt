	quest.7A3DFA518103EC84.quest_desc: [
		"The Derrick is a large 5x17x5 multiblock used to drill the ground to pierce a reservoir."
		""
		"You have one output behind the power port, simply put a tank to get the fluid from the reservoir."
		""
		"When you have finished pumping all the fluid, you can then put a Pumpjack to passively pump the remnant fluids."
		""
		"The Derrick needs Concrete and Water to go through the ground and pump the reservoir."
	]
	quest.7A3DFA518103EC84.title: "Derrick"
