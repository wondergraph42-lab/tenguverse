	quest.00000000000006A0.quest_desc: [
		"The Alloy Kiln is a 2x2x2 multiblock."
		"It is mainly used to make alloy."
	]
	quest.00000000000006A0.title: "Alloy Kiln"
	quest.00000000000006A2.quest_desc: ["The Coke Oven is a 3x3x3 multiblock that produce Coal Coke and Creosote Oil with Coal."]
	quest.00000000000006A2.title: "Coke Oven"
	quest.00000000000006A6.quest_desc: ["he Improved Blast Furnace is the upgraded tier of the Crude Blast Furnace, capable of automation and also of greater speeds once Blast Furnace Preheaters are added."]
	quest.00000000000006A6.title: "Improved Blast Furnace"
	quest.00000000000006A8.quest_desc: [
		"Note: To avoid the completion of all machine quests, completion marks have been put before each of them."
		"You must check these first quests to be able to complete the corresponding machine quest."
	]
	quest.00000000000006A8.title: "Immersive Tools"
	quest.00000000000006AA.quest_desc: [
		"Wire Connectors attach directly to machines, usually to a visible power plug."
		"Using a Wire Coil on a Connector links the first end of the cable. Using the Coil on another Connector or on a Wire Relay completes the connection."
		""
		"The LV Wire can transfer 2048 RF/t through 16 blocks distance."
	]
	quest.00000000000006AA.title: "LV Set"
	quest.00000000000006AE.quest_desc: ["The MV Wire can transfer 8192 RF/t through 16 blocks distance."]
	quest.00000000000006AE.title: "MV Set"
	quest.00000000000006B4.quest_desc: ["The HV Wire can transfer 32 768 RF/t through 32 blocks distance."]
	quest.00000000000006B4.title: "HV Set"
	quest.00000000000006B8.quest_desc: ["The insulated wire can no longer hurt you."]
	quest.00000000000006B8.title: "Insulated Set"
	quest.00000000000006BB.quest_desc: ["The Engineer's Blueprint is used in the Engineer's Workbench to be able to craft certain items."]
	quest.00000000000006BB.quest_subtitle: "Crafting Components"
	quest.00000000000006BF.quest_desc: ["The LV Capacitor can store 100k RF and can transfer I/O 256 RF/t"]
	quest.00000000000006C1.quest_desc: ["The MV Capacitor can store 1M RF and can transfer I/O 1024 RF/t"]
	quest.00000000000006C3.quest_desc: ["The HV Capacitor can store 4M RF and can transfer I/O 4096 RF/t"]
	quest.00000000000006C5.quest_desc: ["Molds are used in the Metal Press."]
	quest.00000000000006C5.title: "Mold Set"
	quest.00000000000006CA.quest_desc: ["To make a HOP Graphite ingot, you need to smelt a HOP Graphite dust, who it's make in a squeezer with Petcoke Dust or Coke Dust."]
	quest.00000000000006CC.quest_desc: ["The Graphite Electrode is needed to properly function the Arc Furnace."]
	quest.00000000000006CC.title: "Graphite Electrode"
	quest.00000000000006CE.quest_desc: ["The Garden Cloche is used to grow crops placed in it."]
	quest.00000000000006D0.quest_desc: [
		"The Faraday Armor protects against the Tesla Coil in low-power mode."
		"In high-power mode however, it increases the damage dealt to the user."
	]
	quest.00000000000006D0.title: "Faraday Suit"
