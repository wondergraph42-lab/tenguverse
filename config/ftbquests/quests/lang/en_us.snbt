	quest.35DF00F1E81A6B18.quest_subtitle: "&bRecommended: ~Lv 46"
	quest.360505F6E85575B3.quest_desc: ["A ghost-type master, Agatha resents young Trainers like Professor Oak who she believes \"forgot what real battles are about.\" Her spite fuels her strength."]
	quest.360505F6E85575B3.quest_subtitle: "&bRecommended: ~Lv 85"
	quest.360505F6E85575B3.title: "Agatha"
	quest.366705735F06E60E.quest_desc: [
		"At the bottom of the inventory, you may have noticed a search bar."
		""
		"This is the &dJust Enough Items&r, or &dJEI&r, search bar. "
		""
		"If you type \"Wood\", for example, the &dJEI &ritem list at the right of the screen will show all items with \"Wood\" in the name."
		""
		"Adding a @ at the start of the search query will show the items from a specific mod, for example @Chipped"
		""
	]
	quest.366705735F06E60E.quest_subtitle: "Read my description!"
	quest.36B56BA1DC105ADB.quest_desc: ["&fRoxanne, the Rock-type Gym Leader of Rustboro City, is one of the official Hoenn Gym World Tour battles. Defeat this leader, claim the matching badge, and continue your regional progression."]
	quest.36B56BA1DC105ADB.quest_subtitle: "&bUnlocked Level Cap: Lv 48"
	quest.36B56BA1DC105ADB.title: "Roxanne"
	quest.36D23AA7ADD23E72.quest_subtitle: "&bRecommended: ~Lv 16"
	quest.37007948ACB367AE.quest_desc: [
		"The Slicer is used to automate Farmer's Delight cutting board crafts. "
		""
		"Be careful that your Slicer turns in the right direction so that the crafts work on a belt."
	]
	quest.370D01CBEF430D10.title: "Capture the legendary &aCelebi"
	quest.3758134D86B48139.quest_desc: ["The Pokémon from Kanto were among the first to be documented by scientists. Their behavior, their characteristics, everything about them bears witness to the history of our world. To start, capture 20 of them. Even in a new world like this, they remain true to their origins."]
	quest.3758134D86B48139.title: "Obtain 20 different Pokémon from Generation 1's Pokédex"
	quest.37BB883174427950.quest_desc: ["The &eInventory Configurator&r allows you to change storage priorities and configure filters."]
	quest.37D2EB82AA016FAE.title: "Quick Ball 2013 9"
	quest.37DC494519537142.quest_desc: ["Some Pokémon from Galar seem linked to ancient tales or legendary figures. Even here, far from their origins, you can sense a certain nobility in their bearing. You are close to completing your study."]
	quest.37DC494519537142.title: "Obtain 80 different Pokémon from Generation 8's Pokédex"
	quest.380524930CF351F6.title: "Dive Ball 2013 9"
	quest.383139A22A980A32.quest_desc: ["Fluid Pipes are blocks used to transport and deal with fluids."]
	quest.383139A22A980A32.title: "Fluid Pipe"
	quest.383EC3D68433F17A.quest_desc: ["Don't think you need a masterball? Trade it for some enchantment books"]
	quest.38D953A534128DDE.quest_subtitle: "&bJungle, Sandy, Thermal, Volcanic"
	quest.38E0112BECD74268.quest_desc: [
		"Shadows Steel is obtained by throwing Chromatic Compound in the End Void."
		""
		"Refined Radiant is obtained by throwing Chromatic Compound in a beacon beam (you can also charge your Compound in Glowstone, Torche, shroomlight, etc. But it's very slow)"
	]
