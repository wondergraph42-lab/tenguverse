	quest.7DC951E5F1621BCC.quest_desc: ["The End is a vast, eerie dimension suspended in the void. Towering obsidian pillars and the mighty Ender Dragon guard this realm’s secrets. Beyond the central island, endless chorus forests and mysterious cities await those brave enough to explore."]
	quest.7DC951E5F1621BCC.quest_subtitle: "The End: A Mysterious Void"
