	quest.39346245919E7CC5.quest_desc: [
		"Craft the &bCobblemon Smartphone&r and unlock its powerful features! With this essential device, you can:  "
		"- Use &aPokeHeal&r every 15 minutes to keep your team in top condition.  "
		"- Access your &bPC&r every 5 seconds for rapid management of your Pokémon."
		""
		"Get crafting and step up your game!"
	]
	quest.39346245919E7CC5.quest_subtitle: "Craft your smartphone to enhance your Pokémon management!"
	quest.39346245919E7CC5.title: "Get Your Cobblemon Smartphone!"
	quest.39718B6A5A7BEC15.quest_desc: ["Note: There is a built-in guide for Create. To access it, you need to hold a key on the wanted item in JEI. The animated guide will then appear."]
	quest.39718B6A5A7BEC15.title: "Andesite Casing"
	quest.398BF6D17522496A.quest_subtitle: "&bForest"
	quest.39E04E696A7D8F0F.quest_subtitle: "&bBamboo, Mountain, Taiga"
	quest.3A09BC46905622C0.quest_desc: [
		"The Coker is a large 5x23x9 multiblock used to process Bitumen into Petcoke."
		"Be aware, the Petcoke will be ejected from the bottom of the structure (there are two output)"
	]
	quest.3A09BC46905622C0.title: "Coker"
	quest.3A50E9847D0436A4.quest_desc: ["The Item Drain drains fluid from items such as buckets and bottles inserted onto it. "]
	quest.3A700EE0221882C0.quest_desc: [
		"To share your quests with your friends, you need to create a team."
		""
		"To do this, type the command: \"/ftbteams party create\" or use the menu at top left."
		""
		"From here, you can click on Settings to configure your team (name, color, description, etc.)."
		""
		"Now you can add your friends from the same interface and start your shared adventure together."
	]
	quest.3A700EE0221882C0.quest_subtitle: "Read my description!"
	quest.3A846B47FEA4A691.quest_desc: ["A cunning gambler and Dark-type specialist, Grimsley views battles like games of chance. With sharp strategy and a flair for theatrics, he leaves challengers wondering if his victories are luck... or fate."]
	quest.3A846B47FEA4A691.quest_subtitle: "&bRecommended: ~Lv 85"
	quest.3A846B47FEA4A691.title: "Grimsley"
	quest.3A882BAB0F731B55.quest_desc: ["A Mechanical Belt is a mechanical component that conveys rotation and moves items and entities."]
	quest.3A88F116F5349A26.quest_desc: ["Farming pokemon is the quickest and best way to obtain many materials. Wool from Wooloo, Milk form Miltank, theres tons of options, so experiment!"]
	quest.3B2A55EAA29B2757.title: "Timer Ball 2013 9"
	quest.3B80211FD37355FC.quest_subtitle: "&bRecommended: ~Lv 40"
	quest.3C6C3D28FF13165D.title: "Defeat Pokemon from each Region"
	quest.3C7CB29A9C64364E.quest_subtitle: "&bRecommended: ~Lv 39"
	quest.3CA28BDDCE5F1D71.quest_desc: [""]
	quest.3CA28BDDCE5F1D71.quest_subtitle: "&eYour first Mechanical Stress Generator. Adding more Wheels increases Stress Capacity. The more sides of the wheel the water covers, the faster the wheel will rotate and the more Stress capacity it will provide. Only flowing water or source blocks with bubble columns count toward the power generation.&r"
	quest.3CA28BDDCE5F1D71.title: "Craft &cWater Wheels"
	quest.3CA6F2785FE34492.quest_desc: ["The Waystone is a powerful tool for quick travel across the world. By activating Waystones, you can teleport between them for faster exploration and travel.\\n\\nTo use a Waystone:\\n1. Find or craft a Waystone (you’ll need a few resources).\\n2. Right-click on the Waystone to activate it.\\n3. Once activated, you can teleport to it from any other Waystone you’ve unlocked.\\n4. To teleport, simply open the Waystone menu and select your destination.\\n\\nNote: You can only teleport to Waystones that you have previously activated. Enjoy your fast travels!"]
	quest.3CA6F2785FE34492.quest_subtitle: "&eWaystone Explanation"
	quest.3CAF9F15954BDEC8.quest_desc: ["The Aether is a majestic realm of floating islands high above the clouds. Lush landscapes, mystical creatures, and ancient ruins create a sense of wonder and adventure. But beware—this paradise is not without its dangers."]
	quest.3CAF9F15954BDEC8.quest_subtitle: "The Aether: A Skybound Paradise"
	quest.3CB9E3EB1314CD98.quest_desc: [
		"&fVirbank City's Poison-type Gym Leader and a fierce punk rocker."
		"&fDefeat Roxie to claim the Toxic Badge."
	]
	quest.3CB9E3EB1314CD98.quest_subtitle: "&bUnlocked Level Cap: Lv 83"
	quest.3CB9E3EB1314CD98.title: "Roxie"
	quest.3CD4614F6001F8D9.title: "&fA Wild &aZygarde &fAppeared!"
	quest.3CD9DE0E7ED97749.quest_desc: ["You know what to do. Punch Trees. Get wood. And become the very best, like no one ever was"]
	quest.3CD9DE0E7ED97749.title: "Welcome to Minecraft"
	quest.3CF47C1F14BA5638.quest_subtitle: "The &cDeployer&r simulates player actions on blocks or entities exactly 2 blocks away from it.&r"
	quest.3CF47C1F14BA5638.title: "Craft &6Deployer"
	quest.3D0A24C140121FA8.title: "Bugsy"
	quest.3D2CD94D18B01173.title: "&fA Wild &dLunala &fAppeared!"
	quest.3D5841B8216C4182.quest_desc: [
		"To share your quests with your friends, you need to create a team."
		""
		"To do this, type the command:"
		"/ftbteams party create."
		""
		"Now go to your inventory menu and click on the button at the top left \"My Team\"."
		"You can, from there, click on Settings to configure your team (name, color, description, etc ...)"
		""
		"You just have to invite your friends with the command:"
		"/ftbteams party invite NAME"
		""
		"Your friends just have to accept, and you are now in a team."
		""
		"If you want to join an already existing team you just have to type the command:"
		"/ftbteams party join TEAM NAME"
	]
	quest.3D6C572FAD455B42.title: "Luxury Ball 2013 10"
	quest.3D7B5ED7DBBD6B06.quest_subtitle: "&bTemperate, Grassland"
	quest.3DA16F8AEBB6323B.quest_desc: ["The Mechanical Drill is a block used to break blocks."]
	quest.3DA9A5792741B9C3.title: "&fA Wild &5Darkrai &fAppeared!"
	quest.3DB4CDB19FD3915F.quest_desc: ["The Mechanical Mixer is a mechanical component that applies Mixing recipes and shapeless Crafting recipes to items in Basins."]
	quest.3DFFA89FE17F9D28.title: "&fA Wild &eVictini &fAppeared!"
	quest.3E0E5DE9A5C07183.quest_subtitle: "The &cSchematicannon&r is a special type of machine used to build structures with the use of &aSchematics&r. It is a useful contraption which is primarily used within &aSurvival Mode&r to deploy structures block-by-block."
	quest.3E70077BADA57BBD.quest_desc: ["The Hose Pulley lets down a hose that can drain bodies of liquids."]
	quest.3ECF2010A8E66F22.quest_subtitle: "Bring back a prehistoric predator!"
	quest.3ECF2010A8E66F22.title: "The Relic Claw"
	quest.3EDCE472AFDF6BCF.quest_desc: ["A Sandy Mulch makes the Berry Tree act like it's in an Arid biome for an infinite duration. "]
	quest.3F06738ADF94C81F.title: "Sport Ball 2013 9"
	quest.3F3BB89A991FE51D.quest_desc: [
		"&6&l🏆 Kalos Trainer Progression — Gym Challenge"
		""
		"&fFace off against Kalos’s most memorable Gym Leaders in a structured series of trainer battles!"
		""
		"&b⏩ &nClick here to view the full trainer path:&r &7"
		"{\"text\":\"Kalos Trainer Graph Link\",\"italic\":true,\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.plantuml.com/plantuml/svg/~1U05jb4zlr30GnU_-5CFsN44h_XMjh4gjn04a9E28X9naDZ6PU8BjTBMWVdUSn5kIJevvVZ_Fcvaajo4Q7uUEr8lOO8T0jcvYxSr9HHi9OVV940VuUEhWhZ54w6hSgSPM226YHuwd7iCiTDWLw8CAhNMzyQPBjpaS3S0-DhmuuE8NbX7-AkCz7--OsCE5nsf-_jxOidKO0bohmfHjxNbmLNPD2GiQyFdHVizzjEmCQGqNx4sAAZqL7j14h4RF_sOV5za8QtHLoYPA7niRKHtOnPobe9Hk4hxPFmXNL-fHPJno3uI7gFQ5_ZpTk7zPQ9KU4_9XBZrseU4h_XviwXsI8Prfo9Qv0mrVSbVFpv_IQxZFJPqjAZKmvr1vqhiKu-Rz6E67QyUL4feA_Sy7G-Wjxi04sD1N-3k9buHT6eV0ixx2tqYyPU-jCmBF-Wf_A_7qYd4GyAIkq5SIVR1Cikwahj0RYHu7EdXRYhfPN-6l9Pu-hes1JUeAtLWMqwdhhOoTTRMnGBYaIxtQx7arItFMf7cUvTAQLoEjSmTBwmHButcvIskUdJHljJPLajPvUSjRCxnXdTzwTPk-a_Jp-mSKoTBA\"}}"
		""
		"&9🔄 Want to switch to the Kalos Gym path?  "
		"&rYou can reset your current series by exchanging a &6Relic Coin&r to switch tracks at any time!"
		""
		"&6Train hard and earn every badge — your Kalos journey begins now!"
	]
	quest.3F3BB89A991FE51D.title: "&6Kalos Trainer Progression"
	quest.3F47DD10970A6D82.title: "Cherish Ball 2013 15"
	quest.3F76551CB015E728.quest_desc: ["Kalos is also the birthplace of Mega Evolution. Although this power is rare, some Pokémon here seem to carry that energy. Continue your research."]
	quest.3F76551CB015E728.title: "Obtain 40 different Pokémon from Generation 6's Pokédex"
	quest.3F83AD208596996B.quest_desc: ["&fCinnabar Island’s Fire-type quiz master brings heat, experience, and explosive offense. Survive the blaze and earn your place beyond Kanto’s flames."]
	quest.3F83AD208596996B.quest_subtitle: "&bUnlocked Level Cap: Lv 26"
	quest.3F83AD208596996B.title: "Blaine"
	quest.3FB784230C7DB37C.title: "Great Ball 2013 5"
	quest.3FC98137542D6E3D.quest_desc: ["Pokémon from Hoenn were born in a region shaped by the elements: volcanoes, dense forests, underwater reefs. Even here, their legacy is felt. Start by capturing ten, to immerse yourself in their diversity. Some sport vibrant colors or surprisingly well-adapted forms for their biotope."]
	quest.3FC98137542D6E3D.title: "Obtain 20 different Pokémon from Generation 3's Pokédex"
	quest.3FE88975B165AFD7.quest_desc: ["Here, Pokémon often have unique evolutionary forms or patterns. Some change with the weather, mood, or environment. Observe closely and begin to unravel their mysteries."]
	quest.3FE88975B165AFD7.title: "Obtain 30 different Pokémon from Generation 6's Pokédex"
	quest.404969058AC4D285.quest_desc: [
		"Similar to &bAE2&r, it allows remote access to your inventory."
		""
		"This version works within a range of 16 blocks from your &eTerminal&r."
	]
	quest.4086D6899C60F723.quest_subtitle: "&bSmart Chutes&r behave similarly to &cBrass Funnels&r. They can be &afiltered&r to only extract certain items, and be stopped with a &credstone signal&r. Unlike funnels, they can insert and extract at the same time, but can only function &dvertically&r. When below a container, &bstack size&r can be specified in the filter. Otherwise, only the &bitem type&r can be specified."
	quest.4086D6899C60F723.title: "Craft &6Smart Chutes"
	quest.40977DC365696DBE.title: "&fA Wild &eLandorus &fAppeared!"
	quest.40B0460C2542627B.quest_desc: ["Cobblemon is just as much about &dexploration&r as it is about Pokémon. Whether you're searching for rare Pokémon, discovering villages, or gathering resources, there's always something new to find.\\n\\nYou'll encounter various excavation sites, dungeons, temples, and other exciting structures across all dimensions!\\n- Keep an eye on the quests for an exploration checklist &7(coming soon)&r \\n\\n&e&lTip:&r &rDon't forget to look for Apricorn trees—they're key for crafting Poké Balls!"]
	quest.40B0460C2542627B.quest_subtitle: "Discover new biomes and resources"
	quest.40B0460C2542627B.title: "&a&lExploration"
	quest.4117DCE0FDD1C403.quest_subtitle: "Used to craft Wires and Rods."
	quest.4117DCE0FDD1C403.title: "Craft &5Rolling Mill"
	quest.4120AB56E16B718C.quest_desc: [
		"The icon in the top left of the screen is the &aFTB Teams &rmenu. This allows you to add other players to your team."
		""
		"On the right of the &aFTB Teams &ricon is the &6Quest Book &ricon, which allows you to access the &6Quest Book &rat any time."
		""
		"Quests are there to stimulate your adventure and guide you through the modpack, earning you rewards along the way."
	]
	quest.4120AB56E16B718C.quest_subtitle: "Read my description!"
	quest.4120AB56E16B718C.title: "&aInventory"
	quest.418E22D6A0DA4064.quest_desc: ["Toms Simple Storage is a mod similar to Applied Energistics 2 and Simple Storage Network. The premise is simple. A storage terminal attached to a chest will let you see the chests inventory. A crafting terminal will let you craft from within the chest. Works with Iron chests too!"]
	quest.418E22D6A0DA4064.quest_subtitle: "Storage made cheap and Easy"
	quest.41BE7F043058A5DF.title: "&fA Wild &dJirachi &fAppeared!"
	quest.41DFD502557D7C84.quest_desc: [
		"&fIn each berry you can see the location of where you can get each of them."
		""
		"&fGood luck collecting them."
	]
