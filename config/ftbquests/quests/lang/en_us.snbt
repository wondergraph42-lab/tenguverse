	quest.5822EA9B8C023762.quest_desc: ["In order to revive pokemon from Fossils, you will need to first analyze the fossil, and then put it in the restoration tank. "]
	quest.583A417D2E097B78.quest_desc: ["The Pokémon of Sinnoh live in extreme conditions. To reach 60 captures, you'll need to explore icy, rocky, or deeply buried areas."]
	quest.583A417D2E097B78.title: "Obtain 60 different Pokémon from Generation 4's Pokédex"
