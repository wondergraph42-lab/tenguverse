	quest.0000000000000754.quest_desc: ["The Pumpjack is a 6×4×3 multiblock, It extracts the remnant fluid that the Derrick have pump."]
	quest.0000000000000754.title: "Pumpjack"
	quest.000000000000075D.quest_desc: [
		"The Distillation Tower is a large 4x16x4 multiblock used to process fluids into other fluids."
