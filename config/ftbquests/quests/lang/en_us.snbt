	quest.0E9284D03A1C0923.title: "Whitney"
	quest.0EC6ADB264C82954.title: "Heavy Ball 2013 9"
	quest.0EC7AC28BC6700F2.quest_desc: ["&fValerie, the Fairy-type Gym Leader of Laverre City, is one of the official Kalos Gym World Tour battles. Defeat this leader, claim the matching badge, and continue your regional progression."]
	quest.0EC7AC28BC6700F2.quest_subtitle: "&bUnlocked Level Cap: Lv 96"
	quest.0EC7AC28BC6700F2.title: "Valerie"
	quest.0ED784ADF48804A2.quest_desc: ["As you progress, you’ll notice how these Pokémon have adapted to a wide range of environments. Kanto species are robust and iconic. With 40 captures, you'll lay a strong foundation for understanding their biological differences."]
	quest.0ED784ADF48804A2.title: "Obtain 40 different Pokémon from Generation 1's Pokédex"
	quest.0EDFECC97E44B508.quest_desc: [""]
	quest.0EDFECC97E44B508.quest_subtitle: "&bThe Sequenced Gearshift allows finer control over Rotational power, allowing multiple changes to the rotation over a period of time.&r"
	quest.0EDFECC97E44B508.title: "Craft &6Sequenced Gearshift"
	quest.0EF14F0D3E9267D6.quest_desc: ["One of the casing use to craft Create components"]
	quest.0F21B16927A39E9A.quest_desc: ["Polished Rose Quartz is a material used to craft Electron Tubes and Chromatic Compound"]
	quest.0F8747577DC13AD3.quest_desc: ["As is nearly always the case, things are much clearer if you '&bPonder'&r, but in this case, you will need to click '&bNext'&r to watch the '&bItem processing with encased fans'&r to see how you can set up an ore washing and smelting process."]
	quest.0F8747577DC13AD3.quest_subtitle: "&bEncased fans&r will push or pull entities, the faster the rotation the further the distance they will push. They are also key to Create's version of ore processing."
	quest.0F8747577DC13AD3.title: "Craft &5Encased Fan"
	quest.0FF657DAAF38D204.quest_subtitle: "The &cThreshold Switch&r measures how full an inventory is and can emit a &bRedstone signal&r at adjustable thresholds.&r"
	quest.0FF657DAAF38D204.title: "Craft &6Threshold Switch"
	quest.102E66D73862EC60.title: "Capture the legendary &eKoko"
	quest.103DD799D79A3D47.quest_desc: ["Alola is more than just a region—it’s a place where natural energies converge. By capturing all of Alola’s Pokémon, you step into the heart of this enchanting world, where the ecosystem is in perfect balance. Congratulations, you’re now part of this region’s living legacy."]
	quest.103DD799D79A3D47.title: "Obtain all 88 different Pokémon from Generation 7's Pokédex"
	quest.105D9AF35881ADF5.quest_desc: ["Pokeballs are the most basic item used to capture wild pokemon. There are various kinds of pokeball with different colors, but all have the same X1 catch rate. "]
	quest.105D9AF35881ADF5.title: "Your first Pokeball"
	quest.10A1016053015870.quest_desc: ["&fViola, the Bug-type Gym Leader of Santalune City, is one of the official Kalos Gym World Tour battles. Defeat this leader, claim the matching badge, and continue your regional progression."]
	quest.10A1016053015870.quest_subtitle: "&bUnlocked Level Cap: Lv 91"
	quest.10A1016053015870.title: "Viola"
	quest.10C2252468961C2F.quest_desc: [
		"&fGlaseado's Ice-type Gym Leader is calm, precise, and brutally cold."
		"&fDefeat Grusha to claim the Ice Badge."
	]
	quest.10C2252468961C2F.quest_subtitle: "&bUnlocked Level Cap: Lv 100"
	quest.10C2252468961C2F.title: "Grusha"
	quest.10F2F596C66BA041.quest_desc: [
		"&bTom's Simple Storage&r is a &esimple&r alternative to &bAE2&r for managing your items."
		""
		"It is designed to be easier to set up while still providing a powerful storage solution."
		""
		"One of the key components of &bTom's Simple Storage&r is the &eStorage Terminal&r."
		"It is the main way of accessing and managing items stored in your &bnetwork&r."
		""
		"Tip: It works very well together with the &bSophisticated Storage&r mod."
	]
	quest.11886FEE23FB1FA0.quest_subtitle: "Build 1 additional PC to help other trainers or for your own collection."
	quest.11A6AE8869E30BA1.quest_desc: [
		"In this pack to make Rose Quartz you will need Fluorite and Redstone."
		"There will be a way to make Rose Quartz with Quartz later."
	]
	quest.1221B21BEBCFBF0C.quest_subtitle: "&bDripstone, Lush, Spooky, Swamp, Taiga"
	quest.12779E7CC3A93EB4.quest_desc: ["The Cogwheel is a basic mechanical component in Create that relays rotation."]
	quest.12779E7CC3A93EB4.title: "Cogwheel"
	quest.127AC3BFAC14DCC3.quest_desc: ["Holds 256 items per slot (8). Retains inventory when broken. Nearby builders can hold the keybind to open it remotely."]
	quest.127AC3BFAC14DCC3.title: "Craft a &eToolbox"
	quest.12D0D3A50BBDCE1F.quest_desc: ["&fMelony, the Ice-type Gym Leader of Circhester, is one of the official Galar Gym World Tour battles. Defeat this leader, claim the matching badge, and continue your regional progression."]
	quest.12D0D3A50BBDCE1F.quest_subtitle: "&bUnlocked Level Cap: Lv 100"
	quest.12D0D3A50BBDCE1F.title: "Melony"
	quest.12FE884009B0DF1A.quest_desc: [
		"The Seismic Survey Tool allows you to see where the reservoir are they, and used a Buckshot Cartridge to function."
		""
		"Right-click a Cartridge in the Seismic Survey, then right-click to shoot, and you get a Survey Result like this."
		"{image:ftbquests:textures/quests/ip_surveyresult.png width:150 height:100 align:1}"
		"You can see a red triangle on top (it's represent North)."
		"The center point is where you shoot your Survey."
		"The white stain represents a reservoir."
		"So you need to move north-west to find your reservoir."
		""
		"Be aware that a Reservoir is not only in one chunk, the reservoir has a shape, and you can see his shape with your Survey Result."
	]
	quest.13418BA96C23EFCA.quest_desc: ["The Portable Energy Interface is the energy version of the Portable Storage Interface. It is used to insert or extract from the energy inventory of a Contraption."]
	quest.1398A4F9E1F3CB1B.title: "Craft&6 Item Drain"
	quest.13E1483EE3CD5675.quest_desc: ["&fNessa, the Water-type Gym Leader of Hulbury, is one of the official Galar Gym World Tour battles. Defeat this leader, claim the matching badge, and continue your regional progression."]
	quest.13E1483EE3CD5675.quest_subtitle: "&bUnlocked Level Cap: Lv 100"
	quest.13E1483EE3CD5675.title: "Nessa"
	quest.14234A407DF24445.quest_desc: ["Engage in and win 50 Pokémon battles! Whether you’re facing wild Pokémon or challenging trainers, every victory brings you closer to becoming a master trainer. Test your strategy, fine-tune your team, and let your skills shine on the battlefield."]
	quest.14234A407DF24445.quest_subtitle: "Prove Your Battling Prowess"
	quest.14234A407DF24445.title: "50 Pokémon Battles"
	quest.142F92D3B83B8F73.title: "&fA Wild &bLatios &fAppeared!"
	quest.147EABFC7C5BB8FF.quest_desc: ["&fA Peat Mulch makes the Berry Tree act like it's in a Forest biome for an infinite duration. "]
	quest.14A9DB8454589823.quest_desc: [
		"The &eInventory Cable Connector&r links different storages together."
		""
		"It allows you to connect two separate inventories within the same &bnetwork&r."
	]
	quest.14E0B2F94E4705BA.quest_desc: [
		"The Smart Observer is a machine that emits a redstone signal dependent on the block or items inside a container in front of it. "
		""
		"A Display Link can be used to display the inventory the Smart Observer observes."
	]
	quest.1502B96487B5F720.quest_desc: ["Train Casing is used to make all the machine in relation with train"]
	quest.1552AE931A4AEF0E.quest_desc: ["Crushing Wheels are the most advanced version of the Millstone. It applies Crushing recipes to any items inserted from the direction they are spinning away from"]
	quest.1552AE931A4AEF0E.title: "Crushing Wheel"
	quest.159D8EFAC4AA0B7F.quest_subtitle: "The Andesite Funnel is used to extract or insert materials into inventories. Can be wrenched to switch from extract and insert. Will be stopped with redstone singal and cant be filtered."
	quest.159D8EFAC4AA0B7F.title: "Craft &bAndesite Funnels"
	quest.15A01CC993137DCF.quest_desc: [
		"The icon in the top left of the screen is the &aFTB Teams &rmenu. This allows you to add other players to your team."
		""
		"On the right of the &aFTB Teams &ricon is the &6Quest Book &ricon, which allows you to access the &6Quest Book &rat any time."
		""
		"Quests are there to stimulate your adventure and guide you through the modpack, earning you rewards along the way."
	]
	quest.15A01CC993137DCF.quest_subtitle: "Read my description!"
	quest.15B31B2B8B90F805.quest_desc: [
		"&fA silent Ghost-type Gym Leader hidden behind a mask."
		"&fDefeat Allister to claim the Ghost Badge."
	]
	quest.15B31B2B8B90F805.quest_subtitle: "&bUnlocked Level Cap: Lv 100"
	quest.15B31B2B8B90F805.title: "Allister"
	quest.15BC1D065F68BA2C.title: "Simple but Powerful Storage"
	quest.15C37CDC1FB0258F.title: "&fA Wild &eZekrom &fAppeared!"
	quest.160837029AE0BB52.title: "Capture the legendary &5Mesprit"
	quest.161061D6B1ECEC71.quest_desc: ["The Nether is a dangerous, lava-filled dimension where survival is a true test of skill. Navigate through crimson forests, basalt deltas, and soul sand valleys while encountering powerful foes and rare resources. Tread carefully—danger lurks around every corner."]
	quest.161061D6B1ECEC71.quest_subtitle: "The Nether: A Fiery Underworld"
	quest.16B1F60A0D8DAD6D.quest_desc: ["Electron Tubes is a material used to craft various components from Create"]
	quest.16D5DB61567D65BA.quest_subtitle: "The &aSpeedometer&r measures the speed of &eRotational Force&r."
	quest.16D5DB61567D65BA.title: "Craft a Speedometer"
	quest.16E55FF6E8BA2998.quest_desc: ["Pokemon may attack you, and you may need to fight them off, as well as the mobs. So its always handy to have a good sword"]
	quest.16E5F30F12932F5C.quest_desc: ["A full block version of the &eCable Connector&r."]
	quest.17156E54E3070B88.quest_desc: [
		"&fXxend has stepped out of the timeline, chasing one thing only &fa worthy fight."
		""
		"&fThis &bStorykeeper Trainer&f can be encountered &eanytime&f in the world."
		"&fFind him, challenge him, and prove you deserve to face the future."
		""
		"&f&lBattle Reward&f: &dSparkling Stone"
	]
	quest.17156E54E3070B88.quest_subtitle: "A Time Traveler that craves the thrill of battle."
	quest.17156E54E3070B88.title: "&b&lXxend, the Time Traveler"
	quest.172C81EF8A61B42E.quest_desc: [
		"The Radial Chassis is a block used to connect Contraptions. "
		"Unlike Linear Chassis, the Radial Chassis connects to a radius of blocks around it rather than a straight line of blocks"
	]
	quest.173D2B8A8694F17A.quest_subtitle: "&bRecommended: ~Lv 81"
	quest.17CB4966931A4981.quest_desc: ["Long ago, when Sinnoh was still called Hisui, Primitive Pokeballs were made with Tumblestones. Back then it was uncommon for people to battle Pokemon before trying to caputre them, as such some of these Ancient Pokeballs have effects that will help when trying to catch a Pokemon out of battle"]
	quest.17D7A2D76CD2E45B.quest_desc: ["Train Stations are used to create, disassemble, and guide Trains."]
	quest.17EDCBE58ADB7DE7.title: "&fA Wild &dSolgaleo &fAppeared!"
	quest.17EE02A867A34A4C.quest_desc: ["&fVermilion City’s Electric-type veteran turns every battle into a voltage test. Ground your strategy before his team overloads the arena."]
	quest.17EE02A867A34A4C.quest_subtitle: "&bUnlocked Level Cap: Lv 25"
	quest.17EE02A867A34A4C.title: "Lt. Surge"
	quest.1864C6A6C75AC4C7.quest_desc: [
		"This tutorial will walk you through some basic features. Rest assured, it won't take too long!"
		""
		"To begin, click the checkmark below the word \"Tasks,\" and then claim your quest reward. New quests will start to appear!"
		""
		"If new quests don't appear, try relaunching your world. Don't get rid of the mushrooms until the tutorial is finished."
	]
	quest.1864C6A6C75AC4C7.quest_subtitle: "To start the tutorial, click on this quest and read the description."
	quest.18B4EAD49DE50658.quest_subtitle: "&bRecommended: ~Lv 74"
	quest.18B4EAD49DE50658.title: "Manta"
	quest.18FE3366B4BEEEB8.quest_desc: ["Johto gave rise to many new evolutions—forms emerging from Pokémon of other regions. These transformations are fascinating to study. With 80 species captured, you’ll have ample data to analyze how environmental conditions shape their development."]
	quest.18FE3366B4BEEEB8.title: "Obtain 80 different Pokémon from Generation 2's Pokédex"
	quest.1909ED480E48557C.quest_desc: [
		"The Mechanical Harvester will harvest all mature crops it comes in contact with while moving forward."
		"It will then either deposit the items on a inventory attach to the contraption, or, if no inventories are available, it will drop the items to the ground."
	]
	quest.19FDF486AFC1C995.quest_subtitle: "&bRecommended: ~Lv 85"
	quest.19FDF486AFC1C995.title: "Maxie"
	quest.1A2E1E124AFB663D.title: "Love Ball 2013 9"
	quest.1A2E68C15E54E1E2.quest_desc: [
		"To get Steel, you're going to need to make a Blast Furnace."
		""
		"It's a 3x3x3 multiblock that alloys Ironwood (in this pack) with CharCoal, Coal Cokes or Pet Cokes to produce Steel."
		""
		"You can use a Hexerei Cauldron to get one in the Twilight Forest."
	]
	quest.1A2E68C15E54E1E2.title: "Blast Furnace"
	quest.1A45DDBDFC0EE3CC.quest_desc: [
		"The &eAdvanced Wireless Terminal&r provides a larger access range, up to 64 blocks."
		""
		"If a &eBeacon&r is placed within 8 blocks of the terminal, the range can be extended depending on the beacon level:"
		""
		"Level 1: Access anywhere in the same dimension."
		"Level 4: Access anywhere across dimensions."
		""
		"Important: The &eTerminal&r and the &eBeacon&r must remain loaded for the network to stay accessible."
	]
	quest.1A50C9B613D17BE3.quest_subtitle: "&bRecommended: ~Lv 80"
	quest.1A50C9B613D17BE3.title: "Tabitha"
	quest.1A513CE71070D2D3.quest_subtitle: "Copper World"
	quest.1A513CE71070D2D3.title: "&6Copper"
	quest.1A55861188EC9CA0.quest_desc: ["Redstone Contacts allow Contraptions to convey redstone signals or activate Redstone Circuits. "]
	quest.1A55861188EC9CA0.title: "Redstone Contact"
	quest.1A84E6A8E3F5DFFA.quest_subtitle: "&bRecommended: ~Lv 80"
	quest.1A84E6A8E3F5DFFA.title: "Courtney"
	quest.1A880DE1FF836830.quest_desc: [
		"The &eLevel Emitter&r sends a redstone signal when a specific item reaches a defined amount in your &bnetwork&r."
		""
		"For example, if it is set to 500 cobblestone, it will emit a signal once your network contains more than 500."
	]
	quest.1AA1807AEB8FC0FF.quest_subtitle: "&bRecommended: ~Lv 69"
	quest.1AA1807AEB8FC0FF.title: "Ray"
	quest.1AFCC8C4B48933C9.quest_desc: ["Cobblemon is just as much about &dexploration&r as it is about Pokémon. Whether you're searching for rare Pokémon, discovering villages, or gathering resources, there's always something new to find.\\n\\nYou'll encounter various excavation sites, dungeons, temples, and other exciting structures across all dimensions!\\n- Keep an eye on the quests for an exploration checklist &7(coming soon)&r \\n\\n&e&lTip:&r &rDon't forget to look for Apricorn trees—they're key for crafting Poké Balls!"]
	quest.1AFCC8C4B48933C9.quest_subtitle: "Discover new biomes and resources"
	quest.1AFCC8C4B48933C9.title: "Exploration and Adventure"
	quest.1B5F85BF8AA75893.quest_desc: ["🐛 Aaron is young, loyal, and passionate about Bug Pokémon. He once struggled with confidence but grew into a true Elite trainer."]
	quest.1B5F85BF8AA75893.quest_subtitle: "&bRecommended: ~Lv 57"
	quest.1B93842B9AD3B422.quest_desc: ["The mysterious final Gym Leader is none other than the boss of Team Rocket. Giovanni's Ground-type mastery reflects his ambition to control from the shadows."]
	quest.1B93842B9AD3B422.quest_subtitle: "&bRecommended: ~Lv 80"
	quest.1B93842B9AD3B422.title: "Giovanni "
	quest.1BCCB3486CD86029.quest_desc: [""]
	quest.1BCCB3486CD86029.quest_subtitle: "Provides a way to interface with moving contraptions to transfer fluids via a fancy docking method. You'll definitely want to Ponder this one."
	quest.1BCCB3486CD86029.title: "Craft &6Portable Fluid Interface"
	quest.1C0FF46184784148.quest_desc: ["Though few in number, the Pokémon of Kalos are now all registered in your encyclopedia. You are worthy of holding this region’s ancient knowledge."]
	quest.1C0FF46184784148.title: "Obtain all 72 different Pokémon from Generation 6's Pokédex"
	quest.1C53247EE7E4F966.quest_desc: ["Trading 1 masterball will get you 20 rare candies. If you really want to level up  your pokemon. Best at higher levels"]
	quest.1C6BDFF8FE947B4B.title: "Capture the legendary &cHo-Oh"
	quest.1C7513DE44B5D77B.quest_desc: ["Collect a bucket of Concrete."]
	quest.1C7C22A12D409120.quest_desc: ["🧠 A master of tactics and literature, Lucian reads both books and minds. He’s the brain of the Elite Four."]
	quest.1C7C22A12D409120.quest_subtitle: "&bRecommended: ~Lv 63"
	quest.1CE221491F9152C6.quest_desc: ["The Large Cogwheel is a larger variant of the cogwheel that can relay rotation around corners and power Rotation Speed Controllers."]
	quest.1CE221491F9152C6.title: "Large Cogwheel"
	quest.1D372D62EC32A485.quest_desc: [
		"The &eInventory Cable&r connects different storage blocks such as chests."
		""
		"With additional components, these inventories can become part of your &bnetwork&r."
	]
	quest.1DCBC94F0A8D171E.quest_desc: [
		"&6&l🏆 Hoenn Trainer Progression — Pokémon League"
		""
		"&fYou’ve reached the summit of Hoenn’s challenge. It’s time to face the Elite Four and the Champion!"
		""
		"&b⏩ &nClick here to view the full League challenge path:&r &7"
