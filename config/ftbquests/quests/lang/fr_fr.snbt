	quest.50072918BCA03E89.title: "Maître d'Alola"
	quest.50A27C2F51A711E2.quest_desc: ["&fGardenia, champion Plante de Eterna City, fait partie des combats officiels du Gym World Tour de Sinnoh. Bats ce champion, récupère le badge correspondant et poursuis ta progression régionale."]
	quest.50A27C2F51A711E2.quest_subtitle: "&bLevel Cap débloqué : Nv 67"
	quest.50A27C2F51A711E2.title: "Gardenia"
	quest.50D00A495DEBD89C.title: "Capturez le légendaire &aViridium"
	quest.51AEA3639258E4F4.title: "Capturez le légendaire &eCobaltium"
	quest.5206DA39EF40267E.quest_desc: ["&fRoark, champion Roche de Oreburgh City, fait partie des combats officiels du Gym World Tour de Sinnoh. Bats ce champion, récupère le badge correspondant et poursuis ta progression régionale."]
	quest.5206DA39EF40267E.quest_subtitle: "&bLevel Cap débloqué : Nv 65"
	quest.5206DA39EF40267E.title: "Roark"
	quest.5271B269DAFB24B0.quest_desc: ["&fLa maîtresse Psy de Safrania frappe avec précision et puissance mentale. Ici, la discipline compte autant que la force brute."]
	quest.5271B269DAFB24B0.quest_subtitle: "&bLevel Cap débloqué : Nv 25"
	quest.5271B269DAFB24B0.title: "Sabrina"
	quest.52A99591B9E9ACA7.quest_desc: [
		"&6&l🏆 Progression du Dresseur de Paldea"
		""
		"&fLe parcours de combat de Paldea n’est pas encore disponible dans Cobblemon Realms, mais arrivera dans une prochaine mise à jour !"
		""
		"&c⚠ Aucune série de Dresseurs disponible pour le moment :&r  "
		"&7Actuellement, aucun Champion ou série de Dresseurs n’a été implémenté pour Paldea. Restez à l’écoute pour les prochaines mises à jour !"
		""
		"&9🎯 En attendant :&r  "
		"&rNous vous recommandons de choisir une série de Dresseurs d’une autre région ou génération. Vous pouvez changer à tout moment en échangeant une &6Relic Coin&r."
		""
		"&6Merci pour votre patience, Dresseur. De grandes aventures vous attendent à Paldea !"
	]
	quest.52A99591B9E9ACA7.title: "&6Progression du Dresseur de Paldea"
	quest.52AA41F4FED839AE.quest_subtitle: "Faites revivre un Pokémon perdu dans les vagues !"
	quest.52AA41F4FED839AE.title: "Le Gardien des Profondeurs"
