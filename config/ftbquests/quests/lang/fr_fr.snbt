	quest.00000000000002D6.quest_desc: ["Tuer des animaux, c'est cruel. Une cruauté délicieuse et juteuse."]
	quest.00000000000002D6.title: "De la nourriture pour des jours"
	quest.00000000000002E0.quest_desc: ["Le Nether est rempli de monstres dangereux. Détruis-les avant qu'ils ne te détruisent."]
	quest.00000000000002E0.title: "Dangers du Nether"
	quest.00000000000002E8.quest_desc: ["La nuit est sombre et effrayante. Les monstres sortent la nuit. Brandis ton épée, vise bien et élimine tes ennemis."]
	quest.00000000000002E8.title: "Mortel"
	quest.00000000000002F6.quest_desc: ["Voyage jusqu'à l'End et abats le dragon de l'End."]
	quest.00000000000002F6.title: "Ici, il y a des dragons"
	quest.00000000000002FB.quest_desc: ["Place un cristal de l'End au centre de chaque côté de la fontaine de l'End pour faire réapparaître le dragon. Tue-le à nouveau pour obtenir un autre œuf."]
