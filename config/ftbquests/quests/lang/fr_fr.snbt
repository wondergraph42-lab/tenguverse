	quest.0CB72CA26B2AC085.quest_desc: [
		"&6&l🏆 Progression des Dresseurs de Kanto — Radical Red"
		""
		"&fSuivez la ligne de combats personnalisée des Dresseurs Radicaux pour affronter les Champions et rivaux emblématiques de Kanto !"
		""
		"&b⏩ &nCliquez ici pour voir le chemin complet des dresseurs :&r &7"
		"{\"text\":\"Lien du Graph Radical Red\",\"italic\":true,\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.plantuml.com/plantuml/svg/~1U06TMKs[...]\"}}"
		""
		"&c⚠ Avertissement sur le système de badges :&r"
		"&7Le système de badges n’est pas encore totalement implémenté. Si vous avez déjà battu un Champion, pas d’inquiétude — vous pourrez réclamer votre badge plus tard. Ce message sera supprimé une fois le système en place !"
		""
		"&9🔄 Vous voulez passer à la progression Radical Red ?"
		"&rVous pouvez réinitialiser votre progression actuelle en échangeant une &6Relique&r à tout moment !"
		""
		"&6Bonne chance, Dresseur. Que votre voyage à travers Kanto soit légendaire !"
	]
	quest.0CB72CA26B2AC085.title: "&6Progression Kanto — Dresseurs"
