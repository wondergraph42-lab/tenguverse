	quest.539C37CE348F0F8B.quest_desc: [
		"Ce filtre fonctionne avec des &etags&r au lieu d'objets spécifiques."
		""
		"Astuce : Appuyez sur F3 + H pour activer les tooltips avancés. Ensuite maintenez Ctrl sur un objet pour voir ses tags."
	]
	quest.53F1B9A4EC8BCE11.title: "Capturez le légendaire &5Créhelf"
	quest.53FAD016D5140970.quest_desc: [
		"&fAgrandis ton &bPokémon du slot 1&f à la taille &cGrande (1.3)&f pour une présence renforcée en combat et en vitrine.  "
		"&c⚠ Rappel : Cela affecte uniquement le premier Pokémon de ton équipe (slot 1). Vérifie bien avant d’utiliser !  "
		""
		"&f💰 Coût : &e30 Realms Coin"
	]
	quest.53FAD016D5140970.quest_subtitle: "&eFais grandir ton Pokémon au-dessus de la moyenne"
