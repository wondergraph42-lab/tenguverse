	quest.567F802438C16BC4.quest_subtitle: "Bienvenue dans les Royaumes de Cobblemon"
	quest.56CAB01FD02AD6C9.quest_desc: ["Calme et réfléchi, Ama balance l’énergie de ses frères Chams et Rachid. Sa stratégie basée sur les Pokémon Eau s’écoule lentement mais sûrement, démontrant que même le plus doux ruisseau peut user la pierre la plus dure."]
	quest.56CAB01FD02AD6C9.quest_subtitle: "&bRecommandé : ~Niv 25"
	quest.56CAB01FD02AD6C9.title: "Ama"
	quest.573A00C9E8AE14F2.quest_desc: [
		"&6&l🏴 Progression du Dresseur de Hoenn — Team Magma"
		""
		"&fPlongez dans le scénario de la Team Magma et affrontez leurs commandants en découvrant leurs ambitions brûlantes !"
		""
		"&b⏩ &nCliquez ici pour voir l’arborescence complète de la Team Magma :&r &7"
		"{\"text\":\"Lien vers le graphique de la Team Magma\",\"italic\":true,\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.plantuml.com/plantuml/svg/...\"}}"
		""
		"&9🔄 Vous voulez changer pour la série Team Magma ?"
		"&rVous pouvez réinitialiser votre progression actuelle en échangeant une &6Relic Coin&r à tout moment !"
		""
		"&6Affrontez leur chaleur et réécrivez le destin de Hoenn !"
	]
	quest.573A00C9E8AE14F2.title: "&cTeam Magma"
	quest.5764756A85C07AF3.quest_desc: [
		"&6&l🏆 Progression du Dresseur d’Unys — Champions et Rivaux"
		""
		"&fCommencez votre aventure à Unys en affrontant les puissants Champions d’Arène et les rivaux inoubliables comme Bianca, Tcheren et Komor !"
