	quest.431C1794B3E50F8D.title: "Grant"
	quest.43577F5781B8C662.quest_desc: ["Aldo, le sage errant d’Unys, est devenu Maître après avoir subi une grande perte. Il enseigne que la véritable force naît des liens entre Pokémon et Dresseur, et non de la puissance brute."]
	quest.43577F5781B8C662.quest_subtitle: "&bRecommandé : ~Niv 90"
	quest.43577F5781B8C662.title: "Aldo"
	quest.43658622BCC515DF.quest_subtitle: "Êtes-vous prêt ? Une seule tentative."
