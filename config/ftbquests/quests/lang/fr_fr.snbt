	quest.44657056937D017E.quest_desc: ["&fRamos, champion Plante de Coumarine City, fait partie des combats officiels du Gym World Tour de Kalos. Bats ce champion, récupère le badge correspondant et poursuis ta progression régionale."]
	quest.44657056937D017E.quest_subtitle: "&bLevel Cap débloqué : Nv 94"
